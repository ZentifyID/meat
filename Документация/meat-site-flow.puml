@startuml
title Диаграмма работы сайта "Производство мясопродуктов"

skinparam backgroundColor white
skinparam shadowing false
skinparam defaultFontName Arial
skinparam activity {
  BackgroundColor #EFEAFF
  BorderColor #8C7AE6
  DiamondBackgroundColor #FFF1D6
  DiamondBorderColor #C98F2B
  StartColor #B8E6C1
  EndColor #F3B0B0
  BarColor #8C7AE6
  FontColor #333333
}

start

:Пользователь сайта;

if (Авторизован?) then (Да)
  :Переход в личный кабинет;
else (Нет)
  :Регистрация / Вход;
endif

:Просмотр главной страницы;
:Переход в каталог товаров;
:Поиск товара по названию;
:Фильтрация по категории;
:Просмотр карточки товара;

if (Товар доступен?) then (Да)
  :Добавление товара в корзину;
else (Нет)
  :Продолжить просмотр каталога;
endif

if (В корзине есть товары?) then (Да)
  :Просмотр корзины;
  :Изменение количества\nили удаление позиции;
  :Оформление заказа;
  :Ввод ФИО, телефона,\nemail и адреса доставки;
  :Создание заказа;
  :Переход на страницу успешного заказа;
else (Нет)
  :Возврат к покупкам;
endif

if (Пользователь авторизован?) then (Да)
  :Просмотр истории заказов\nв личном кабинете;
  :Просмотр своих отзывов;
else (Нет)
endif

:Отправка отзыва;
:Модерация отзыва администратором;
:Публикация отзыва на сайте;

:Просмотр новостей;
:Переход на страницу контактов;

stop
@enduml
